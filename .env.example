# Public canonical site URL. Leave unset locally; production falls back to
# https://www.scottchentools.com when this is missing or non-canonical.
NEXT_PUBLIC_SITE_URL=https://www.scottchentools.com

# Inquiry delivery — configure ONE of the two paths below.

# Preferred: forward inquiry submissions to a webhook (e.g. Feishu/Slack/Zapier).
INQUIRY_WEBHOOK_URL=

# Fallback: send inquiry emails via Resend.
RESEND_API_KEY=
INQUIRY_FROM_EMAIL=
INQUIRY_TO_EMAIL=

# Optional: send an auto-reply email to the visitor (requires Resend).
INQUIRY_AUTO_REPLY_ENABLED=false
INQUIRY_AUTO_REPLY_FROM=

# Optional: Google Analytics, loaded only after visitor consent.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
