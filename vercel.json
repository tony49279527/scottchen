{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "build": {
    "env": {
      "NEXT_PUBLIC_SITE_URL": "https://www.scottchentools.com"
    }
  },
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "scottchentools.com" }],
      "destination": "https://www.scottchentools.com/:path*",
      "permanent": true
    }
  ]
}
